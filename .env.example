# คัดลอกไฟล์นี้เป็น .env.local แล้วใส่ค่าจริง (.env.local ไม่ถูก commit เข้า git อยู่แล้ว)

# Personal Access Token ของ GitHub ที่มีสิทธิ์เขียนไฟล์ใน repo นี้
# สร้างได้ที่ https://github.com/settings/tokens (แนะนำ Fine-grained token จำกัดสิทธิ์เฉพาะ repo นี้
# และเลือก permission "Contents: Read and write" เท่านั้น)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# เจ้าของ repo และชื่อ repo ที่จะใช้เก็บข้อมูล JSON
GITHUB_REPO_OWNER=maleeart
GITHUB_REPO_NAME=Veri

# branch สำหรับเก็บข้อมูล JSON (แยกจาก branch โค้ด main เพื่อไม่ให้ข้อมูลหายตอนอัพเดทแอพ)
# ถ้าไม่ตั้งค่า จะใช้ "data" เป็น default และสร้างให้อัตโนมัติถ้ายังไม่มี
GITHUB_REPO_BRANCH=data
